# Mend scanner configuration — TKA-10392 reproduction
#
# KEY SETTINGS:
#   nuget.runPreStep=false  — prevents scanner from calling `dotnet restore`,
#                             which would trigger MSB4242 when workload 10.0.101.1
#                             is absent from the CI runner.
#   nuget.resolveSystemPackages=true — surfaces Microsoft.* / workload-delivered
#                             packages that are otherwise filtered out by default.

nuget.runPreStep=false
nuget.resolveSystemPackages=true
